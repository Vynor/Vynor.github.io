 $m$ \u4e2a\uff0c\u65e0\u6cd5\u64cd\u4f5c\u4e3a\u8f93\u3002", "top": 0, "createdAt": 1724853445, "style": "<style>.markdown-alert{padding:0.5rem 1rem;margin-bottom:1rem;border-left:.25em solid var(--borderColor-default,var(--color-border-default));}.markdown-alert .markdown-alert-title {display:flex;font-weight:var(--base-text-weight-medium,500);align-items:center;line-height:1;}.markdown-alert>:first-child {margin-top:0;}.markdown-alert>:last-child {margin-bottom:0;}</style><style>.markdown-alert.markdown-alert-tip {border-left-color:var(--borderColor-success-emphasis, var(--color-success-emphasis));background-color:var(--color-success-subtle);}.markdown-alert.markdown-alert-tip .markdown-alert-title {color: var(--fgColor-success,var(--color-success-fg));}</style><style>.markdown-alert.markdown-alert-important {border-left-color:var(--borderColor-done-emphasis, var(--color-done-emphasis));background-color:var(--color-done-subtle);}.markdown-alert.markdown-alert-important .markdown-alert-title {color: var(--fgColor-done,var(--color-done-fg));}</style>", "script": "<script src='https://blog.meekdai.com/Gmeek/plugins/GmeekTOC.js'></script><script>MathJax = {tex: {inlineMath: [[\"$\", \"$\"]]}};</script><script async src=\"https://cdn.jsdelivr.net/npm/mathjax@3/es5/tex-mml-chtml.js\"></script>", "head": "", "ogImage": "https://github.githubassets.com/favicons/favicon.svg", "createdDate": "2024-08-28", "dateLabelColor": "#bc4c00"}, "P9": {"htmlDir": "docs/post/guan-yu-zai-zi-fu-chuan-xia-de-dong-tai-gui-hua-he-ji-yi-hua-sou-suo-de-shi-yong-si-kao.html", "labels": ["\u601d\u8003"], "postTitle": "\u5173\u4e8e\u5728\u5b57\u7b26\u4e32\u4e0b\u7684\u52a8\u6001\u89c4\u5212\u548c\u8bb0\u5fc6\u5316\u641c\u7d22\u7684\u4f7f\u7528\u601d\u8003", "postUrl": "post/guan-yu-zai-zi-fu-chuan-xia-de-dong-tai-gui-hua-he-ji-yi-hua-sou-suo-de-shi-yong-si-kao.html", "postSourceUrl": "https://github.com/Vynor/Vynor.github.io/issues/9", "commentNum": 0, "wordCount": 1980, "description": "\u5148\u770b\u4e24\u9053\u9898\r\n\u9898\u76ee\u4e00\uff1a[zbw\u7684\u7b7e\u5230](https://icpc.qlu.edu.cn/p/P2407)\r\n**\u9898\u76ee\u63cf\u8ff0**\r\n\u4e00\u4e2a\u5408\u6cd5\u7684\u5b57\u7b26\u4e32\u5b9a\u4e49\u4e3a\r\n- \u7531\u5c0f\u5199\u5b57\u6bcd\u7ec4\u6210\r\n- \u5305\u542b**\u5b50\u5e8f\u5217**'cn'\r\n\r\n\u95ee\u957f\u5ea6\u5728 $n(n \\le 3e5)$ \u4ee5\u5185\u7684\u5408\u6cd5\u5b57\u7b26\u4e32\u7684\u6570\u91cf\r\n\r\n\u9898\u76ee\u4e8c\uff1a[\u5b57\u7b26\u4e32\u66ff\u6362](https://icpc.qlu.edu.cn/p/P2496)\r\n[\u9898\u76ee\u63cf\u8ff0](https://vynor.github.io/post/pai-wei-sai-ti-jie-%28Updating%29.html#day4g%E5%AD%97%E7%AC%A6%E4%B8%B2%E6%9B%BF%E6%8D%A2)\r\n(\u672c\u535a\u5ba2\u6709\u6536\u5f55)\r\n\r\n\u95ee\u5728\u6240\u6709\u5b57\u7b26\u4e32 $t$ \u4e2d\uff0c\u5b50\u5e8f\u5217'abc'\u51fa\u73b0\u7684\u6b21\u6570\u4e4b\u548c\r\n\r\n\u4e8c\u8005**\u533a\u522b**\u5728\u4e8e\u4e00\u4e2a\u5b57\u7b26\u4e32\u5bf9\u4e8e\u7b54\u6848\u6765\u8bf4\uff0c\u80fd\u4e3a\u9898\u76ee\u4e00\u81f3\u591a\u5e26\u67651\u7684\u8d21\u732e\uff0c\u800c\u5bf9\u9898\u76ee\u4e8c\u80fd\u5e26\u6765\u4e0d\u6b621\u7684\u8d21\u732e\u3002", "top": 0, "createdAt": 1724898782, "style": "", "script": "<script>MathJax = {tex: {inlineMath: [[\"$\", \"$\"]]}};</script><script async src=\"https://cdn.jsdelivr.net/npm/mathjax@3/es5/tex-mml-chtml.js\"></script>", "head": "", "ogImage": "https://github.githubassets.com/favicons/favicon.svg", "createdDate": "2024-08-29", "dateLabelColor": "#bc4c00"}, "P10": {"htmlDir": "docs/post/zui-duan-lu.html", "labels": ["\u6a21\u677f"], "postTitle": "\u6700\u77ed\u8def", "postUrl": "post/zui-duan-lu.html", "postSourceUrl": "https://github.com/Vynor/Vynor.github.io/issues/10", "commentNum": 0, "wordCount": 4171, "description": "# Dijkstra #\r\n\u5355\u6e90\u6c47\u6700\u77ed\u8def\uff0c\u8981\u6c42\u56fe\u4e0a**\u4e0d\u5b58\u5728**\u8d1f\u6743\u8fb9\r\n\u65f6\u95f4\u590d\u6742\u5ea6\u4e3a $O((N+M)logN)$\r\n> [!IMPORTANT]\r\n> \u7ecf\u66b4\u6253\uff0c\u4f7f\u7528\u4f18\u5148\u961f\u5217\u7684\u65f6\u95f4\u66f4\u4f18\uff0c\u56e0\u4e3a\u5e38\u6570\u66f4\u5c0f\uff0c\u5c0f\u5fc3\u88ab**Set**\u5361\u5e38\u54e6\r\n\r\n**\u4f18\u5148\u961f\u5217**\r\n```c++\r\nint d[N];\r\nint st[N];\r\n\r\nusing pt = pair<int, int>;\r\n\r\nvoid dij(int s, int u)\r\n{\r\n    memset(d, 0x3f, sizeof d);\r\n    memset(st, false, sizeof st);\r\n    d[s] = 0;\r\n    priority_queue<pt, vector<pt>, greater<pt>> q;\r\n    q.push({d[s], s});\r\n    while (!q.empty())\r\n    {\r\n        int x = q.top().second;\r\n        q.pop();\r\n        if (st[x])\r\n            continue;\r\n        st[x] = true;\r\n        for (auto [y, v] : edge[x])\r\n            if (d[y] > d[x] + v)\r\n            {\r\n                d[y] = d[x] + v;\r\n                q.push({d[y], y});\r\n            }\r\n    }\r\n}\r\n```\r\n**Set**\r\n```c++\r\nvector<pair<int, int>> edge[N];\r\n\r\nint n, m, s;\r\nint dist[N];\r\n\r\nset<pair<int, int>> q;\r\n\r\nvoid dij(int s){\r\n    memset(dist, 127, sizeof dist);\r\n    dist[s] = 0; q.clear();\r\n    for (int i = 1; i <= n; i ++ ) \r\n        q.insert(make_pair(dist[i], i));\r\n    while (!q.empty()){\r\n        int x = q.begin()->second;\r\n        q.erase(q.begin());\r\n        if (dist[x] > 1 << 30) break;//\u65e0\u6cd5\u62b5\u8fbex\r\n        for (auto [y, v]:edge[x])\r\n            if (dist[y] > dist[x] + v){\r\n                q.erase(make_pair(dist[y], y));\r\n                dist[y] = dist[x] + v;\r\n                q.insert(make_pair(dist[y], y));\r\n            }\r\n    }    \r\n}\r\n```\r\n\r\n# Bellman-Ford #\r\nBellman\u2013Ford \u7b97\u6cd5\u662f\u4e00\u79cd\u57fa\u4e8e\u677e\u5f1b\uff08relax\uff09\u64cd\u4f5c\u7684\u6700\u77ed\u8def\u7b97\u6cd5\uff0c\u53ef\u4ee5\u6c42\u51fa\u6709\u8d1f\u6743\u7684\u56fe\u7684\u6700\u77ed\u8def\uff0c\u5e76\u53ef\u4ee5\u5bf9\u6700\u77ed\u8def\u4e0d\u5b58\u5728\u7684\u60c5\u51b5\u8fdb\u884c\u5224\u65ad\u3002", "top": 0, "createdAt": 1724913266, "style": "<style>.markdown-alert{padding:0.5rem 1rem;margin-bottom:1rem;border-left:.25em solid var(--borderColor-default,var(--color-border-default));}.markdown-alert .markdown-alert-title {display:flex;font-weight:var(--base-text-weight-medium,500);align-items:center;line-height:1;}.markdown-alert>:first-child {margin-top:0;}.markdown-alert>:last-child {margin-bottom:0;}</style><style>.markdown-alert.markdown-alert-important {border-left-color:var(--borderColor-done-emphasis, var(--color-done-emphasis));background-color:var(--color-done-subtle);}.markdown-alert.markdown-alert-important .markdown-alert-title {color: var(--fgColor-done,var(--color-done-fg));}</style><style>.markdown-alert.markdown-alert-warning {border-left-color:var(--borderColor-attention-emphasis, var(--color-attention-emphasis));background-color:var(--color-attention-subtle);}.markdown-alert.markdown-alert-warning .markdown-alert-title {color: var(--fgColor-attention,var(--color-attention-fg));}</style>", "script": "<script src='https://blog.meekdai.com/Gmeek/plugins/GmeekTOC.js'></script><script>MathJax = {tex: {inlineMath: [[\"$\", \"$\"]]}};</script><script async src=\"https://cdn.jsdelivr.net/npm/mathjax@3/es5/tex-mml-chtml.js\"></script>", "head": "", "ogImage": "https://github.githubassets.com/favicons/favicon.svg", "createdDate": "2024-08-29", "dateLabelColor": "#bc4c00"}, "P11": {"htmlDir": "docs/post/369ABC-ti-jie.html", "labels": ["Atcoder"], "postTitle": "369ABC\u9898\u89e3", "postUrl": "post/369ABC-ti-jie.html", "postSourceUrl": "https://github.com/Vynor/Vynor.github.io/issues/11", "commentNum": 0, "wordCount": 5223, "description": "# D - Bonus EXP # \r\n\u7b80\u5355DP\r\n\u8bbe\u7f6e $dp[i][j]$ \u4ee3\u8868\u8003\u8651\u9009\u62e9\u524d $i$ \u4e2a\u5143\u7d20\u51fb\u6740\uff0c\u51fb\u6740\u6b21\u6570\u7684\u5947\u5076\u6027\u662f $j(1 or 0)$\u7684\u6700\u5927\u503c\u3002", "top": 0, "createdAt": 1725178227, "style": "", "script": "<script src='https://blog.meekdai.com/Gmeek/plugins/GmeekTOC.js'></script><script>MathJax = {tex: {inlineMath: [[\"$\", \"$\"]]}};</script><script async src=\"https://cdn.jsdelivr.net/npm/mathjax@3/es5/tex-mml-chtml.js\"></script>", "head": "", "ogImage": "https://github.githubassets.com/favicons/favicon.svg", "createdDate": "2024-09-01", "dateLabelColor": "#bc4c00"}, "P13": {"htmlDir": "docs/post/yi-wei-de-yi-lai-ti-jie-shi-man-xing-si-wang.html", "labels": ["\u601d\u8003"], "postTitle": "\u4e00\u5473\u7684\u4f9d\u8d56\u9898\u89e3\u662f\u6162\u6027\u6b7b\u4ea1", "postUrl": "post/yi-wei-de-yi-lai-ti-jie-shi-man-xing-si-wang.html", "postSourceUrl": "https://github.com/Vynor/Vynor.github.io/issues/13", "commentNum": 0, "wordCount": 99, "description": "\u9898\u89e3\u662f\u68a6\u5e7b\uff0c\r\n\u5979\u7ed9\u4eba\u505a\u9898\u7684\u5e0c\u671b\uff1b\r\n\u9898\u89e3\u53c8\u662f\u6bd2\u836f\uff0c\r\n\u5979\u7ed9\u4eba\u5355\u5411\u7684\u7ebf\u6027\u601d\u8003\uff0c\u8150\u8680\u5fc3\u7075\u3002", "top": 0, "createdAt": 1725704754, "style": "", "script": "", "head": "", "ogImage": "https://github.githubassets.com/favicons/favicon.svg", "createdDate": "2024-09-07", "dateLabelColor": "#bc4c00"}, "P15": {"htmlDir": "docs/post/370ABC-ti-jie.html", "labels": ["Atcoder"], "postTitle": "370ABC\u9898\u89e3", "postUrl": "post/370ABC-ti-jie.html", "postSourceUrl": "https://github.com/Vynor/Vynor.github.io/issues/15", "commentNum": 0, "wordCount": 4168, "description": "## D - Cross Explosion ##\r\n\u8003\u5bdf\u5bf9**Set**\u7684\u4f7f\u7528\uff0c\u5c24\u5176\u662f**prev**\u51fd\u6570\r\n```c++\r\nvoid solve() {\r\n    int n, m;\r\n    cin >> n >> m;\r\n    vector<vector<bool>> st(n + 1, vector<bool>(m + 1, false));\r\n    vector<set<int>> u(m + 2), d(m + 2), l(n + 2), r(n + 2);\r\n    for (int i = 0; i <= n + 1; i ++ )\r\n        for (int j = 0; j <= m + 1; j ++ ){\r\n            l[i].insert(j), r[i].insert(j);\r\n            u[j].insert(i), d[j].insert(i);\r\n        }\r\n\r\n    auto gao = [&](int x, int y){ //\u7206\u7834\u51fd\u6570\r\n        st[x][y] = true;\r\n        l[x].erase(y);\r\n        r[x].erase(y);\r\n        u[y].erase(x);\r\n        d[y].erase(x);\r\n    };\r\n\r\n    int q;\r\n    cin >> q;\r\n    int cnt = 0;\r\n    while (q -- ){\r\n        int x, y;\r\n        cin >> x >> y;\r\n        if (!st[x][y]){\r\n            gao(x, y);\r\n        }else{\r\n            //4\u4e2a\u65b9\u5411\r\n            //\u53f3\r\n            auto ir = r[x].upper_bound(y),\r\n                il = prev(l[x].upper_bound(y)),\r\n                iu = prev(u[y].upper_bound(x)),\r\n                id = d[y].upper_bound(x);\r\n            if (*ir >= 1 && *ir <= m) {\r\n                gao(x, *ir);\r\n            }\r\n            if (*il >= 1 && *il <= m){\r\n                gao(x, *il);\r\n            }\r\n            if (*iu >= 1 && *iu <= n){\r\n                gao(*iu, y);\r\n            }\r\n            if (*id >= 1 && *id <= n){\r\n                gao(*id, y);\r\n            }\r\n        }\r\n    }\r\n    int ans = 0;\r\n    for (int i = 1; i <= n; i ++ )\r\n        for (int j = 1; j <= m; j ++ )\r\n            ans += !st[i][j];\r\n    cout << ans;\r\n}\r\n```\r\n\r\n## E - Avoid K Partition ##\r\n\u8003\u8651dp\r\ndp[i]\u8868\u793a\u53ea\u8003\u8651\u524di\u4e2a\u5e76\u4ee5\u7b2ci\u4e2a\u7ed3\u5c3e\u7684\u65b9\u6848\u6570\r\n\u53ef\u4ee5\u679a\u4e3e\u524d\u4e00\u4e2a\u5206\u754c\u70b9\u6765\u8fdb\u884cN^2\u7684\u66b4\u529b\u8f6c\u79fb\r\n**if ()**\r\n    **dp[i] += dp[j] (j < i && sum[i] - sum[j] != K)**\r\n\u7edf\u8ba1\u6ee1\u8db3 $sum[j] != sum[i] - K$ \u592a\u96be\uff0c\u56e0\u4e3a\u5de6\u8fb9\u662f\u53d8\u91cf\r\n\u4e0d\u59a8\u53cd\u5411\u7edf\u8ba1 $sum[i] - sum[j] = K$\r\n\u90a3\u4e48 $sum[j] = sum[i] - K$\r\n\u7136\u540e\u7528\u603b\u6570\u51cf\u53bb\u4e0d\u5408\u6cd5j\u7684\u65b9\u6848\u6570\u3002", "top": 0, "createdAt": 1726047780, "style": "", "script": "<script src='https://blog.meekdai.com/Gmeek/plugins/GmeekTOC.js'></script><script>MathJax = {tex: {inlineMath: [[\"$\", \"$\"]]}};</script><script async src=\"https://cdn.jsdelivr.net/npm/mathjax@3/es5/tex-mml-chtml.js\"></script>", "head": "", "ogImage": "https://github.githubassets.com/favicons/favicon.svg", "createdDate": "2024-09-11", "dateLabelColor": "#bc4c00"}, "P16": {"htmlDir": "docs/post/371ABC-ti-jie.html", "labels": ["Atcoder"], "postTitle": "371ABC\u9898\u89e3", "postUrl": "post/371ABC-ti-jie.html", "postSourceUrl": "https://github.com/Vynor/Vynor.github.io/issues/16", "commentNum": 0, "wordCount": 5375, "description": "## D - 1D Country ##\r\n\u5bf9\u4e8e\u6bcf\u6b21\u8be2\u95ee\r\n\u4e8c\u5206\u51fa\u5bf9\u5e94\u7684L\u6751\u5e84\u7f16\u53f7\u548cR\u6751\u5e84\u7f16\u53f7\r\n\u6751\u5e84\u7f16\u53f7\u4e3a\u524d\u7f00\u548c\u4e0b\u6807\uff0c\u524d\u7f00\u548c\u5904\u7406\u533a\u95f4\u548c\u3002", "top": 0, "createdAt": 1726647682, "style": "<style>.markdown-alert{padding:0.5rem 1rem;margin-bottom:1rem;border-left:.25em solid var(--borderColor-default,var(--color-border-default));}.markdown-alert .markdown-alert-title {display:flex;font-weight:var(--base-text-weight-medium,500);align-items:center;line-height:1;}.markdown-alert>:first-child {margin-top:0;}.markdown-alert>:last-child {margin-bottom:0;}</style><style>.markdown-alert.markdown-alert-tip {border-left-color:var(--borderColor-success-emphasis, var(--color-success-emphasis));background-color:var(--color-success-subtle);}.markdown-alert.markdown-alert-tip .markdown-alert-title {color: var(--fgColor-success,var(--color-success-fg));}</style>", "script": "<script src='https://blog.meekdai.com/Gmeek/plugins/GmeekTOC.js'></script><script>MathJax = {tex: {inlineMath: [[\"$\", \"$\"]]}};</script><script async src=\"https://cdn.jsdelivr.net/npm/mathjax@3/es5/tex-mml-chtml.js\"></script>", "head": "", "ogImage": "https://github.githubassets.com/favicons/favicon.svg", "createdDate": "2024-09-18", "dateLabelColor": "#bc4c00"}, "P17": {"htmlDir": "docs/post/372ABC-ti-jie.html", "labels": ["Atcoder"], "postTitle": "372ABC\u9898\u89e3", "postUrl": "post/372ABC-ti-jie.html", "postSourceUrl": "https://github.com/Vynor/Vynor.github.io/issues/17", "commentNum": 0, "wordCount": 2840, "description": "## B - 3^A ##\r\n3\u8fdb\u5236\uff0c\u603b\u662f\u8d2a\u5fc3\u4f7f\u7528\u9ad8\u4f4d\uff0c\u4f7f\u5f97\u4f7f\u7528\u7684\u6570\u76ee\u6700\u5c0f\r\n```c++\r\nvoid solve() {\r\n    vector<int> b(20);\r\n    b[0] = 1;\r\n    for (int i = 1; i <= 10; i ++ ) b[i] = b[i - 1] * 3;\r\n    int m;\r\n    cin >> m;\r\n    vector<int> ans;\r\n    for (int j = 10; j >= 0; j -- )\r\n        if (b[j] <= m){\r\n            int t = m / b[j];\r\n            m -= t * b[j];\r\n            while (t -- ) ans.push_back(j);\r\n        }\r\n    cout << ans.size() << '\\n';\r\n    for (auto x : ans)\r\n        cout << x << ' ';\r\n}\r\n```\r\n\r\n## D - Buildings ##\r\n\u719f\u7ec3\u4f7f\u7528\u6570\u636e\u7ed3\u6784\u6808**Stack**\r\n```c++\r\n#include<bits/stdc++.h>\r\n#define IOS ios::sync_with_stdio(false);cin.tie(0);cout.tie(0)\r\n\r\nusing namespace std;\r\n\r\nvoid solve() {\r\n    int n;\r\n    cin >> n;\r\n    vector<int> a(n + 1), ans(n + 1);\r\n    stack<int> st;\r\n    for (int i = 1; i <= n; i ++ ) cin >> a[i];\r\n    for (int i = n; i >= 1; i -- ){\r\n        int x = a[i];\r\n        while (!st.empty() && x > st.top()) st.pop();\r\n        st.push(x);\r\n        ans[i - 1] = st.size();\r\n    }\r\n    for (int i = 1; i <= n; i ++ ){\r\n        cout << ans[i] << ' ';\r\n    }\r\n}\r\n```\r\n\r\n## E - K-th Largest Connected Components ##\r\n\u8054\u7cfb\u901a\u8def\uff0c\u5e76\u67e5\u96c6\r\n\u5408\u5e76\u5e76\u67e5\u96c6\u65f6\u9700\u8981\u5408\u5e762\u4e2a\u5e76\u67e5\u96c6\u5185\u7684\u9876\u70b9\uff0c\u663e\u7136**Set**\u6c42\u6709\u5e8f\u3002", "top": 0, "createdAt": 1726927961, "style": "", "script": "<script src='https://blog.meekdai.com/Gmeek/plugins/GmeekTOC.js'></script><script>MathJax = {tex: {inlineMath: [[\"$\", \"$\"]]}};</script><script async src=\"https://cdn.jsdelivr.net/npm/mathjax@3/es5/tex-mml-chtml.js\"></script>", "head": "", "ogImage": "https://github.githubasse